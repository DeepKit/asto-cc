[Unit]
Description=asto.cc FastAPI Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/asto/asto.cc
ExecStart=/srv/goodmem.cn/app/current/goodmem.cn/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
